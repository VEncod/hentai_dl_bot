# Telegram API credentials (from https://my.telegram.org)
API_ID=12345678
API_HASH=your_api_hash_here

# Bot token (from @BotFather)
BOT_TOKEN=123456:ABC-DEF1234ghIkl-zyx57W2v1u123ew11

# MongoDB connection string
MONGO_URL=mongodb+srv://user:pass@cluster.mongodb.net/

# NOTE: CACHE_CHANNEL is no longer required.
# Use /setchannel in the bot to configure the main archive channel.
# Use /setlog in the bot to configure the log channel.
# The first user to /start the bot becomes the owner (super admin).
